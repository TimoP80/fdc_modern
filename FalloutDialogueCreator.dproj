<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <ProjectVersion>19.4</ProjectVersion>
    <FrameworkType>VCL</FrameworkType>
    <MainSource>FalloutDialogueCreator.dpr</MainSource>
    <Base>True</Base>
    <Config Condition="'$(Config)'==''">Debug</Config>
    <Platform Condition="'$(Platform)'==''">Win32</Platform>
    <TargetedPlatforms>1</TargetedPlatforms>
    <AppType>Application</AppType>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Base' or '$(Base)'!=''">
    <DCC_DcuOutput>.\$(Platform)\$(Config)</DCC_DcuOutput>
    <DCC_ExeOutput>.\$(Platform)\$(Config)</DCC_ExeOutput>
    <DCC_DpkOutput>.\$(Platform)\$(Config)</DCC_DpkOutput>
    <DCC_Define>DEBUG</DCC_Define>
    <DCC_UsePackage>vclimg;vcl;rtl;vclwinx;vclactnband;vcldb;dbrtl</DCC_UsePackage>
    <Manifest_File>none</Manifest_File>
    <VerInfo_IncludeVerInfo>true</VerInfo_IncludeVerInfo>
    <VerInfo_Locale>1033</VerInfo_Locale>
    <VerInfo_Keys>CompanyName=;FileDescription=Fallout Dialogue Creator;FileVersion=1.0.0.0;InternalName=;LegalCopyright=;LegalTrademarks=;OriginalFilename=FalloutDialogueCreator.exe;ProductName=Fallout Dialogue Creator;ProductVersion=1.0.0.0;Comments=</VerInfo_Keys>
    <DCC_Namespace>Winapi;System.Win;Data.Win;Datasnap.Win;Web.Win;Soap.Win;Xml.Win;Bde;$(DCC_Namespace)</DCC_Namespace>
    <Icon_MainIcon>FDC_Icon.ico</Icon_MainIcon>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Release' and '$(Platform)'=='Win32'">
    <DCC_Optimize>true</DCC_Optimize>
    <DCC_DebugInformation>0</DCC_DebugInformation>
    <DCC_Define>RELEASE</DCC_Define>
    <Linked_iCLBoost>false</Linked_iCLBoost>
    <DCC_ExeOutput>.\bin\</DCC_ExeOutput>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Debug' and '$(Platform)'=='Win32'">
    <DCC_Optimize>false</DCC_Optimize>
    <DCC_DebugInformation>2</DCC_DebugInformation>
    <DCC_Define>DEBUG</DCC_Define>
    <DCC_RemoteDebug>false</DCC_RemoteDebug>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Release' and '$(Platform)'=='Win64'">
    <DCC_Optimize>true</DCC_Optimize>
    <DCC_DebugInformation>0</DCC_DebugInformation>
    <DCC_Define>RELEASE</DCC_Define>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Debug' and '$(Platform)'=='Win64'">
    <DCC_Optimize>false</DCC_Optimize>
    <DCC_DebugInformation>2</DCC_DebugInformation>
    <DCC_Define>DEBUG</DCC_Define>
  </PropertyGroup>
  <ItemGroup>
    <DelphiCompile Include="$(MainSource)">
      <MainSource>MainSource</MainSource>
    </DelphiCompile>
    <DCCReference Include="uMainForm.pas">
      <Form>MainForm</Form>
    </DCCReference>
    <DCCReference Include="uDialogueTypes.pas"/>
    <DCCReference Include="uDialogueNode.pas"/>
    <DCCReference Include="uNodeCanvas.pas"/>
    <DCCReference Include="uThemeManager.pas"/>
    <DCCReference Include="uProjectManager.pas"/>
    <DCCReference Include="uExportManager.pas"/>
    <DCCReference Include="uNodeProperties.pas">
      <Form>NodePropertiesForm</Form>
    </DCCReference>
    <DCCReference Include="uPreviewSystem.pas">
      <Form>PreviewForm</Form>
    </DCCReference>
    <DCCReference Include="uFloatMessageEditor.pas">
      <Form>FloatMessageForm</Form>
    </DCCReference>
    <DCCReference Include="uValidationTools.pas">
      <Form>ValidationForm</Form>
    </DCCReference>
    <DCCReference Include="uSkillCheckEditor.pas">
      <Form>SkillCheckEditorForm</Form>
    </DCCReference>
    <DCCReference Include="uScriptEditor.pas">
      <Form>ScriptEditorForm</Form>
    </DCCReference>
    <DCCReference Include="uLocalization.pas">
      <Form>LocalizationForm</Form>
    </DCCReference>
    <DCCReference Include="uAssetBrowser.pas">
      <Form>AssetBrowserForm</Form>
    </DCCReference>
    <DCCReference Include="uSearchPanel.pas"/>
  </ItemGroup>
  <ProjectExtensions>
    <Borland.Personality>Delphi.Personality.12</Borland.Personality>
    <Borland.ProjectType>Application</Borland.ProjectType>
    <BorlandProject>
      <BorlandProject.Delphi.Personality>
        <Source>
          <Source Name="MainSource">FalloutDialogueCreator.dpr</Source>
        </Source>
      </BorlandProject.Delphi.Personality>
    </BorlandProject>
  </ProjectExtensions>
  <Import Project="$(BDS)\Bin\CodeGear.Delphi.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')"/>
  <Import Project="$(APPDATA)\Embarcadero\Studio\$(ProductVersion)\UserTools.proj" Condition="Exists('$(APPDATA)\Embarcadero\Studio\$(ProductVersion)\UserTools.proj')"/>
</Project>