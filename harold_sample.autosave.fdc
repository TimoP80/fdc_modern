        {
          "id": "OPT_VAULT_INFO",
          "text": "I'm looking for information about the vault.",
          "targetNodeId": "N_VAULT_INFO_001",
          "isHidden": false,
          "hasSkillCheck": false,
          "scriptOnSelect": "",
          "reputationRequired": 0,
          "karmaRequired": -1000,
          "itemRequired": ""
        },
        {
          "id": "OPT_SPEECH_CHARM",
          "text": "[Speech 60%] Maybe we can help each other out. I have caps.",
          "targetNodeId": "",
          "isHidden": false,
          "hasSkillCheck": true,
          "scriptOnSelect": "give_xp(25);",
          "reputationRequired": 0,
          "karmaRequired": -1000,
          "itemRequired": "",
          "skillCheck": {
            "skill": 0,
            "difficulty": 60,
            "critBonus": 10,
            "xpReward": 50,
            "successMsg": "Your silver tongue works its magic on the old ghoul.",
            "failMsg": "Harold sees right through your silver-tongued act.",
            "successNode": "N_SPEECH_SUCCESS",
            "failNode": "N_SPEECH_FAIL"
          }
        },
        {
          "id": "OPT_TRADE",
          "text": "What do you have for trade?",
          "targetNodeId": "N_TRADE_NODE",
          "isHidden": false,
          "hasSkillCheck": false,
          "scriptOnSelect": "",
          "reputationRequired": 0,
          "karmaRequired": -1000,
