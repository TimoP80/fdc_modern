      "scripts": [
        {
          "event": 4,
          "code": "procedure OnQuestUpdate(questID: string; state: Integer);\nbegin\n  set_global_var(\"GVAR_VAULT_LOCATION_KNOWN\", 1);\n  add_journal(questID, state);\n  give_xp(100);\nend;",
          "enabled": true
        }
      ]
    },
    {
      "id": "N_SPEECH_SUCCESS",
      "type": "0",
      "text": "Ha! Now you're talking my language. Alright, I'll tell you what I know — and believe me, Harold knows plenty. Pull up a rock and sit down. It's a long story, and Bob here gets cranky if I rush it.",
      "speaker": "Harold",
      "portrait": "",
      "voice": "",
      "x": 1060,
      "y": 40,
      "width": 280,
      "height": 140,
      "color": -16773104,
      "comment": "Harold opens up after successful speech check",
      "questId": "",
      "questFlag": "",
      "scriptFile": "",
      "reputation": 0,
      "karma": -1000,
      "tag": "speech_success",
      "notes": "This leads to more info - Harold is willing to talk at length now.",
      "nextNodeId": "N_END_NODE",
      "isStartNode": false,
      "randomWeight": 1,
      "combatScript": "",
      "tradeInventory": "",
      "options": [
      ],
      "conditions": [
      ],
      "scripts": [
        {
          "event": 1,
          "code": "procedure OnNodeEnter(npc, player: TEntity; nodeID: string);\nbegin\n  modify_rep(\"HAROLD_FACTION\", 10);\nend;",
          "enabled": true
        }
      ]
    },
    {
      "id": "N_SPEECH_FAIL",
      "type": "0",
      "text": "Caps? You think Harold can be bought that easy? I've been around since before you were a twinkle in your daddy's eye. Go peddle that somewhere else, kid.",
      "speaker": "Harold",
      "portrait": "",
      "voice": "",
      "x": 1060,
      "y": 220,
      "width": 280,
      "height": 120,
      "color": -16773104,
      "comment": "Harold rejects the player's bribery attempt",
      "questId": "",
      "questFlag": "",
      "scriptFile": "",
      "reputation": 0,
      "karma": -1000,
      "tag": "speech_fail",
      "notes": "",
      "nextNodeId": "N_END_NODE",
      "isStartNode": false,
      "randomWeight": 1,
      "combatScript": "",
      "tradeInventory": "",
      "options": [
      ],
      "conditions": [
        {
          "type": 2,
          "variable": "HAROLD_FACTION",
          "operator": 3,
          "value": "-50",
          "boolOp": 0
        }
      ],
      "scripts": [
      ]
    },
    {
      "id": "N_TRADE_NODE",
      "type": "7",
      "text": "Fine, let's see what you've got. But don't try to cheat old Harold — I've been around long enough to know a bad deal when I see one.",
      "speaker": "Harold",
      "portrait": "",
      "voice": "",
      "x": 780,
      "y": 380,
      "width": 240,
      "height": 100,
      "color": -16775936,
      "comment": "Opens barter/trade interface",
      "questId": "",
      "questFlag": "",
      "scriptFile": "",
      "reputation": 0,
      "karma": -1000,
      "tag": "trade",
      "notes": "",
      "nextNodeId": "N_END_NODE",
      "isStartNode": false,
      "randomWeight": 1,
      "combatScript": "",
      "tradeInventory": "RadAway x3; Stimpak x5; Brahmin Jerky x10",
      "options": [
