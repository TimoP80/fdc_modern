{
  "name": "Harold the Ghoul - Sample Dialogue",
  "npcName": "Harold",
  "npcScript": "harold_dialogue",
  "description": "A sample branching dialogue tree demonstrating all FDC features. Harold is a recurring character from the Fallout series — a half-human, half-ghoul wanderer with a tree growing from his head.",
