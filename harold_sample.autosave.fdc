    {
      "id": "N_VAULT_INFO_001",
      "type": "0",
      "text": "The vault? Heh, you and half the wasteland. Word is there's an old Vault-Tec facility east of here, past the rad scorpion territory. Can't miss it — look for the mountain with the big crack in it. But I wouldn't go there alone if I were you.",
      "speaker": "Harold",
      "portrait": "",
      "voice": "",
      "x": 780,
      "y": 40,
      "width": 280,
      "height": 160,
      "color": -16773104,
      "comment": "Harold gives vault location info",
      "questId": "FIND_THE_VAULT",
      "questFlag": "",
      "scriptFile": "",
      "reputation": 0,
      "karma": -1000,
      "tag": "vault_info",
      "notes": "Quest update should trigger after this node.",
      "nextNodeId": "N_QUEST_UPDATE_VAULT",
      "isStartNode": false,
      "randomWeight": 1,
      "combatScript": "",
      "tradeInventory": "",
      "options": [
      ],
      "conditions": [
      ],
      "scripts": [
      ]
    },
    {
      "id": "N_QUEST_UPDATE_VAULT",
      "type": "6",
      "text": "",
      "speaker": "",
      "portrait": "",
      "voice": "",
      "x": 780,
      "y": 220,
      "width": 200,
      "height": 80,
      "color": -16773376,
      "comment": "Updates the Find the Vault quest",
      "questId": "FIND_THE_VAULT",
      "questFlag": "1",
      "scriptFile": "",
      "reputation": 0,
      "karma": -1000,
      "tag": "quest_update",
      "notes": "",
