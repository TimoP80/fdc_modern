  "activeLocale": "en-US",
  "locales": "en-US,de-DE,fr-FR,ru-RU",
  "tags": "sample,harold,ghoul,demo",
  "nodes": [
    {
      "id": "N_START_NODE_001",
      "type": "0",
      "text": "Oh, another wanderer passing through the wasteland. Guess you're not here to trade, or you would've said so by now. What do you want?",
      "speaker": "Harold",
      "portrait": "",
      "voice": "",
      "x": 60,
      "y": 80,
      "width": 280,
      "height": 140,
      "color": -16773104,
      "comment": "Opening node - first contact with Harold",
      "questId": "",
      "questFlag": "",
      "scriptFile": "",
      "reputation": 0,
      "karma": -1000,
      "tag": "greeting",
      "notes": "Harold is suspicious but not hostile. Keep tone world-weary.",
      "nextNodeId": "N_PLAYER_REPLIES_001",
      "isStartNode": true,
      "randomWeight": 1,
      "combatScript": "",
      "tradeInventory": "",
      "options": [
      ],
      "conditions": [
      ],
