  "floatMessages": [
    {
      "id": "FLOAT_AMBIENT_001",
      "category": "Ambient",
      "text": "Damned rad scorpions... they're getting worse every year.",
      "priority": 5,
      "weight": 3,
      "condition": "",
      "timedDuration": 4.0,
      "isAmbient": true,
      "isCombatTaunt": false,
      "isContextSensitive": false,
      "localeKey": "harold_bark_scorpions"
    },
    {
      "id": "FLOAT_AMBIENT_002",
      "category": "Ambient",
      "text": "I've seen things that would make your hair fall out. Not that mine didn't already.",
      "priority": 6,
      "weight": 2,
      "condition": "",
      "timedDuration": 4.5,
      "isAmbient": true,
      "isCombatTaunt": false,
      "isContextSensitive": false,
      "localeKey": "harold_bark_hair"
    },
    {
      "id": "FLOAT_AMBIENT_003",
      "category": "Ambient",
      "text": "Bob says hello. ...Don't ask who Bob is.",
      "priority": 4,
      "weight": 2,
      "condition": "",
      "timedDuration": 3.5,
      "isAmbient": true,
      "isCombatTaunt": false,
      "isContextSensitive": false,
      "localeKey": "harold_bark_bob"
    },
    {
      "id": "FLOAT_COMBAT_001",
      "category": "Combat Taunt",
      "text": "Don't make me call Bob!",
      "priority": 8,
      "weight": 1,
      "condition": "",
      "timedDuration": 2.5,
      "isAmbient": false,
      "isCombatTaunt": true,
      "isContextSensitive": false,
      "localeKey": "harold_taunt_bob"
    },
    {
      "id": "FLOAT_COMBAT_002",
      "category": "Combat Taunt",
      "text": "I've survived the Great War, I can survive you!",
      "priority": 9,
      "weight": 1,
      "condition": "",
      "timedDuration": 3.0,
      "isAmbient": false,
      "isCombatTaunt": true,
      "isContextSensitive": false,
      "localeKey": "harold_taunt_war"
    },
    {
      "id": "FLOAT_CONTEXT_001",
      "category": "Context",
      "text": "You know about the vault? Now we're getting somewhere.",
      "priority": 7,
      "weight": 1,
      "condition": "global_var(\"GVAR_VAULT_LOCATION_KNOWN\") == 1",
      "timedDuration": 4.0,
      "isAmbient": false,
      "isCombatTaunt": false,
      "isContextSensitive": true,
      "localeKey": "harold_context_vault_known"
    }
  ],
